// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  name          String
  avatarColor   String    @default("#3b82f6") // Hex color
  role          String    @default("USER") // ADMIN, USER
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  assignedCards Card[]    @relation("AssignedCards")
  comments      Comment[]
}

model Lane {
  id        String   @id @default(uuid())
  title     String
  order     Int
  type      String   @default("DEFAULT") // DEFAULT, BACKLOG, ARCHIVE
  cards     Card[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Card {
  id            String    @id @default(uuid())
  title         String
  headerId      String?   // e.g. "CL-102"
  description   String?
  plannedStart  DateTime?
  plannedFinish DateTime?
  priority      String    @default("Normal") // Low, Normal, High, Urgent
  status        String    @default("Unblocked") // Blocked, Unblocked
  externalLink  String?
  
  orderNumber   String?
  pickupDate    DateTime?
  laneId        String
  lane          Lane      @relation(fields: [laneId], references: [id])
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  resolvedAt    DateTime?

  tags          Tag[]
  comments      Comment[]
  assignedUsers User[]    @relation("AssignedCards")
  followUp      FollowUp?
}


model FollowUp {
  id               String   @id @default(uuid())
  cardId           String   @unique
  card             Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  lastFollowUpDate DateTime
  nextFollowUpDate DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Tag {
  id      String @id @default(uuid())
  name    String @unique
  color   String @default("#e5e7eb")
  cards   Card[]
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  senderName  String
  cardId      String
  cardTitle   String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
}
